---
import type { HTMLAttributes } from "astro/types";
import IconRss from "@/assets/icons/IconRss.svg";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={[{ "mt-auto": !noMarginTop }, "border-t border-accent", className]}
  {...attrs}
>
  <div
    class:list={[
      "app-layout",
      "py-6 sm:py-4",
      "flex flex-col items-center justify-between sm:flex-row-reverse",
    ]}
  >
    <Socials />
    <div class="my-2 flex items-center gap-5 text-sm text-foreground/50">
      <nav class="flex items-center gap-4">
        <a href="/about" class="hover:text-accent transition-colors">About</a>
        <a
          href="/rss.xml"
          class="hover:text-accent transition-colors"
          aria-label="RSS feed"
          title="RSS feed"
        >
          <IconRss class="inline-block size-4" />
        </a>
      </nav>
      <span>&#169; {currentYear}</span>
    </div>
  </div>
</footer>
