---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import getUniqueArtists from "@/utils/getUniqueArtists";
import getReviewsByArtist from "@/utils/getReviewsByArtist";
import { SITE } from "@/config";

const allReviews = await getCollection("reviews");
const artists = getUniqueArtists(allReviews);

const artistsWithCounts = artists.map(({ artist, artistName }) => ({
  artist,
  artistName,
  count: getReviewsByArtist(allReviews, artist).length,
}));
---

<Layout title={`Artists | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Artists" pageDesc="Browse reviews by artist.">
    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      {
        artistsWithCounts.map(({ artist, artistName, count }) => (
          <li>
            <a
              href={`/artists/${artist}/`}
              class="group flex flex-col gap-1 border border-border p-4 transition-all hover:border-accent hover:border-l-[3px] hover:-translate-y-0.5"
            >
              <span class="font-display text-sm font-bold uppercase tracking-widest group-hover:text-accent transition-colors">
                {artistName}
              </span>
              <span class="font-mono text-xs text-foreground/50">
                {count} {count === 1 ? "review" : "reviews"}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Main>
  <Footer />
</Layout>
